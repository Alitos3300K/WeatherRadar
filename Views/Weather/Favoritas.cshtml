@model List<WeatherRadar.Models.CiudadFavorita>
@{
    ViewData["Title"] = "Ciudades Favoritas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-family:'Orbitron',sans-serif; color:#00d4ff;">⭐ Ciudades Favoritas</h2>
    <span class="badge" style="background:#00d4ff; color:#010a1a; font-size:.9rem;">@Model.Count ciudades</span>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p style="font-size:3rem;">🌍</p>
        <p style="color:#4a9bbe;">No tienes ciudades favoritas aún.</p>
        <a asp-action="Index" class="btn-accent">Buscar ciudad</a>
    </div>
}
else
{
    <div class="card-dark p-4">
        <div class="table-responsive">
            <table class="table table-dark-custom table-borderless align-middle">
                <thead>
                    <tr>
                        <th>Ciudad</th>
                        <th>País</th>
                        <th>Guardada el</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ciudad in Model)
                    {
                        <tr>
                            <td>
                                <strong style="color:#00d4ff;">@ciudad.NombreCiudad</strong>
                            </td>
                            <td style="color:#4a9bbe;">@ciudad.Pais</td>
                            <td style="color:#4a9bbe; font-size:.85rem;">
                                @ciudad.FechaGuardado.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                <form method="post" asp-action="Buscar" class="d-inline">
                                    <input type="hidden" name="ciudad" value="@ciudad.NombreCiudad" />
                                    <button type="submit" class="btn btn-sm" style="background:rgba(0,212,255,0.1); color:#00d4ff; border:1px solid rgba(0,212,255,0.3);">
                                        🔍 Ver clima
                                    </button>
                                </form>
                                <form method="post" asp-action="EliminarFavorita" class="d-inline ms-1">
                                    <input type="hidden" name="id" value="@ciudad.Id" />
                                    <button type="submit" class="btn btn-sm" style="background:rgba(255,50,50,0.1); color:#ff6b6b; border:1px solid rgba(255,50,50,0.3);">
                                        🗑️ Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}