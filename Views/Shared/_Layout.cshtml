<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — WeatherRadar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --brand:       #010a1a;
            --accent:      #00d4ff;
            --accent-soft: #7df9ff;
            --surface:     #020f24;
            --card:        #041830;
            --text-light:  #e0f4ff;
            --text-muted:  #4a9bbe;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--brand);
            color: var(--text-light);
            min-height: 100vh;
            background-image: radial-gradient(ellipse at top, #020f24 0%, #010a1a 100%);
        }
        .navbar-brand {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.4rem;
            color: var(--accent) !important;
            letter-spacing: 2px;
            text-shadow: 0 0 20px rgba(0,212,255,0.5);
        }
        .navbar {
            background: rgba(2,15,36,0.95) !important;
            border-bottom: 1px solid rgba(0,212,255,0.3);
            backdrop-filter: blur(10px);
        }
        .nav-link { color: var(--text-light) !important; font-weight: 500; }
        .nav-link:hover { color: var(--accent) !important; }
        .btn-accent {
            background: linear-gradient(135deg, #00d4ff, #0099cc);
            border: none;
            color: #010a1a;
            font-weight: 700;
            padding: .55rem 1.8rem;
            border-radius: 6px;
            transition: all .2s;
            letter-spacing: .5px;
        }
        .btn-accent:hover {
            background: linear-gradient(135deg, #7df9ff, #00d4ff);
            transform: translateY(-1px);
            box-shadow: 0 4px 20px rgba(0,212,255,0.4);
            color: #010a1a;
        }
        .card-dark {
            background: var(--card);
            border: 1px solid rgba(0,212,255,0.2);
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(0,212,255,0.08);
        }
        .table-dark-custom { background: transparent; color: var(--text-light); }
        .table-dark-custom thead tr { border-bottom: 2px solid var(--accent); }
        .table-dark-custom thead th { color: var(--accent); font-weight: 600; letter-spacing: .5px; }
        .table-dark-custom tbody tr:hover { background: rgba(0,212,255,0.05); }
        footer { border-top: 1px solid rgba(0,212,255,0.1); color: var(--text-muted); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Weather" asp-action="Index">⚡ WeatherRadar</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Weather" asp-action="Index">🔍 Buscar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Weather" asp-action="Favoritas">⭐ Favoritas</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        @RenderBody()
    </main>

    <footer class="text-center py-3 mt-4" style="font-size:.85rem;">
        WeatherRadar © @DateTime.Now.Year — Powered by OpenWeatherMap
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>