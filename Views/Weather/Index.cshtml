@{
    ViewData["Title"] = "Buscar Clima";
}

<div class="row justify-content-center mb-5">
    <div class="col-lg-7 text-center">
        <h1 class="display-5 fw-bold mb-2" style="font-family:'Orbitron',sans-serif; color:#00d4ff; text-shadow: 0 0 30px rgba(0,212,255,0.4);">
            ⚡ WeatherRadar
        </h1>
        <p style="color:#4a9bbe;" class="mb-4">Consulta el clima de cualquier ciudad del mundo en tiempo real</p>

        <form method="post" asp-action="Buscar" id="searchForm">
            <div class="input-group input-group-lg shadow">
                <input type="text"
                       name="ciudad"
                       id="ciudadInput"
                       class="form-control border-0 text-light"
                       placeholder="Ej: Bogotá, Londres, Tokyo..."
                       style="background:#041830; border-radius:8px 0 0 8px;" />
                <button type="submit" class="btn-accent" style="border-radius:0 8px 8px 0; padding: 0 1.8rem;">
                    Buscar
                </button>
            </div>
            <div id="errorMsg" class="text-danger mt-2 d-none small">⚠️ Por favor ingresa el nombre de una ciudad.</div>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert mt-3" style="background:rgba(255,50,50,0.1); border:1px solid rgba(255,50,50,0.3); color:#ff6b6b;">
                ❌ @ViewBag.Error
            </div>
        }
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 text-center">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card-dark p-3">
                    <div style="font-size:2rem;">🌡️</div>
                    <p style="color:#4a9bbe; font-size:.85rem;" class="mb-0">Temperatura en tiempo real</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-dark p-3">
                    <div style="font-size:2rem;">📅</div>
                    <p style="color:#4a9bbe; font-size:.85rem;" class="mb-0">Pronóstico 5 días</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-dark p-3">
                    <div style="font-size:2rem;">⭐</div>
                    <p style="color:#4a9bbe; font-size:.85rem;" class="mb-0">Ciudades favoritas</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchForm').addEventListener('submit', function (e) {
            const val = document.getElementById('ciudadInput').value.trim();
            if (!val) {
                e.preventDefault();
                document.getElementById('errorMsg').classList.remove('d-none');
            }
        });
        document.getElementById('ciudadInput').addEventListener('input', function () {
            document.getElementById('errorMsg').classList.add('d-none');
        });
    </script>
}